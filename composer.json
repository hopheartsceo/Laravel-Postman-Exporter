{
    "name": "wessaal/laravel-postman-exporter",
    "description": "Automatically generate Postman v2.1 collections from your Laravel application routes, controllers, and FormRequest validations.",
    "keywords": [
        "laravel",
        "postman",
        "api",
        "collection",
        "exporter",
        "generator",
        "routes"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Wessaal",
            "email": "info@wessaal.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Wessaal\\PostmanExporter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wessaal\\PostmanExporter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wessaal\\PostmanExporter\\PostmanExporterServiceProvider"
            ],
            "aliases": {
                "PostmanExporter": "Wessaal\\PostmanExporter\\Facades\\PostmanExporter"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    }
}
